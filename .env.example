# Example environment variables for local development and deployment.
#
# Secrets (server-side only):
# Keep these out of source control. Use `.env.local` for local development
# and set real secrets in your hosting provider for production.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Public or app URL (safe to expose to client if needed):
# If this value is required on the client side, prefix with NEXT_PUBLIC_.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Notes:
# - Create a `.env.local` file in the project root with the real values.
# - Do NOT commit `.env.local` to version control.
